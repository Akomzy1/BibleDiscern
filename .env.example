# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic / Claude AI
ANTHROPIC_API_KEY=
# Optional model overrides (defaults: claude-opus-4-8 premium / claude-sonnet-5 free)
ANTHROPIC_MODEL_PREMIUM=
ANTHROPIC_MODEL_FREE=

# Stripe (Web payments)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PREMIUM_MONTHLY=
STRIPE_PRICE_ID_PREMIUM_ANNUAL=

# RevenueCat (Mobile IAP)
REVENUECAT_API_KEY=
REVENUECAT_WEBHOOK_SECRET=

# Apple IAP
APPLE_SHARED_SECRET=

# Email (Resend)
RESEND_API_KEY=

# Expo Push Notifications (mobile — parked)
EXPO_PUSH_ACCESS_TOKEN=

# Web Push (VAPID) — v2 PWA
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Cron (Vercel scheduled jobs: follow-ups, daily reminders)
CRON_SECRET=

# Account deletion confirmation tokens (falls back to service role key if unset)
DELETE_ACCOUNT_JWT_SECRET=

# App URL
NEXT_PUBLIC_APP_URL=https://biblediscern.app
