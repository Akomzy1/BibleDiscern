{
  "expo": {
    "name": "LibratoAi",
    "slug": "librato-ai",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "librato",
    "assetBundlePatterns": ["**/*"],

    "icon": "./assets/icon.png",

    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FDF6EC"
    },

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.librato.ai",
      "buildNumber": "1",
      "icon": "./assets/icon.png",
      "requireFullScreen": false,
      "infoPlist": {
        "NSCameraUsageDescription": "LibratoAi does not use the camera. This key is included for future features.",
        "NSMicrophoneUsageDescription": "LibratoAi does not use the microphone. This key is included for future features.",
        "NSPhotoLibraryUsageDescription": "LibratoAi does not access your photo library.",
        "NSLocationWhenInUseUsageDescription": "LibratoAi does not use your location.",
        "NSUserTrackingUsageDescription": "LibratoAi does not track you across other apps or websites.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "associatedDomains": [
        "applinks:librato.ai"
      ],
      "usesAppleSignIn": true,
      "config": {
        "usesNonExemptEncryption": false
      }
    },

    "android": {
      "package": "com.librato.ai",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon-android.png",
        "backgroundColor": "#1B2A4A"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "librato.ai",
              "pathPrefix": "/discern"
            },
            {
              "scheme": "https",
              "host": "librato.ai",
              "pathPrefix": "/journal"
            },
            {
              "scheme": "https",
              "host": "librato.ai",
              "pathPrefix": "/upgrade"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.SCHEDULE_EXACT_ALARM"
      ]
    },

    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-apple-authentication",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#C8A45E",
          "sounds": [],
          "androidMode": "default",
          "androidCollapsedTitle": "LibratoAi"
        }
      ],
      [
        "expo-font",
        {
          "fonts": []
        }
      ]
    ],

    "experiments": {
      "typedRoutes": true
    },

    "extra": {
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    }
  }
}
