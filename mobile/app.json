{
  "expo": {
    "name": "BibleDiscern",
    "slug": "bible-discern",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "librato",
    "assetBundlePatterns": [
      "**/*"
    ],
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FDF6EC"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.biblediscern",
      "buildNumber": "1",
      "icon": "./assets/icon.png",
      "requireFullScreen": false,
      "infoPlist": {
        "NSCameraUsageDescription": "BibleDiscern does not use the camera. This key is included for future features.",
        "NSMicrophoneUsageDescription": "BibleDiscern does not use the microphone. This key is included for future features.",
        "NSPhotoLibraryUsageDescription": "BibleDiscern does not access your photo library.",
        "NSLocationWhenInUseUsageDescription": "BibleDiscern does not use your location.",
        "NSUserTrackingUsageDescription": "BibleDiscern does not track you across other apps or websites.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "associatedDomains": [
        "applinks:librato.ai"
      ],
      "usesAppleSignIn": true,
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.biblediscern",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon-android.png",
        "backgroundColor": "#1B2A4A"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "librato.ai",
              "pathPrefix": "/discern"
            },
            {
              "scheme": "https",
              "host": "librato.ai",
              "pathPrefix": "/journal"
            },
            {
              "scheme": "https",
              "host": "librato.ai",
              "pathPrefix": "/upgrade"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.SCHEDULE_EXACT_ALARM"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#C8A45E",
          "sounds": [],
          "androidMode": "default",
          "androidCollapsedTitle": "BibleDiscern"
        }
      ],
      [
        "expo-font",
        {
          "fonts": []
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "da18b8a1-17e6-466a-b283-f8c0702bf599"
      },
      "router": {
        "origin": false
      }
    },
    "owner": "akomzyai"
  }
}
